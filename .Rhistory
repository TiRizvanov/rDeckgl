library(rDeckgl)
# 1. Generate some random data
set.seed(42)
n <- 2000
df <- data.frame(
lng = rnorm(n, -122.4, 0.02),
lat = rnorm(n, 37.76, 0.02),
val = runif(n)
)
# 2. Define the Deck.gl spec
# We use standard ScatterplotLayer with JSON data for reliability.
# To use Arrow/DuckDB, ensure you have valid GeoArrow data and use GeoArrow layers.
spec <- list(
initialViewState = list(
longitude = -122.4,
latitude = 37.76,
zoom = 12,
pitch = 0,
bearing = 0
),
layers = list(
list(
"@@type" = "ScatterplotLayer",
id = "json-layer",
data = df,
getPosition = "@@=[lng, lat]",
getFillColor = "@@=[255 * val, 0, 255 * (1-val)]",
getRadius = 50,
pickable = TRUE
)
)
)
# 3. Render the widget
w <- deckgl(spec)
htmlwidgets::saveWidget(w, "index.html", selfcontained = FALSE)
print("Saved to index.html")
w
library(rDeckgl)
# 1. Generate some random data
set.seed(42)
n <- 2000
df <- data.frame(
lng = rnorm(n, -122.4, 0.02),
lat = rnorm(n, 37.76, 0.02),
val = runif(n)
)
# 2. Define the Deck.gl spec
# We use standard ScatterplotLayer with JSON data for reliability.
# To use Arrow/DuckDB, ensure you have valid GeoArrow data and use GeoArrow layers.
spec <- list(
initialViewState = list(
longitude = -122.4,
latitude = 37.76,
zoom = 12,
pitch = 0,
bearing = 0
),
layers = list(
list(
"@@type" = "ScatterplotLayer",
id = "json-layer",
data = df,
getPosition = htmlwidgets::JS("d => [d.lng, d.lat]"),
getFillColor = htmlwidgets::JS("d => [255 * d.val, 0, 255 * (1 - d.val)]"),
getRadius = 50,
pickable = TRUE
)
)
)
# 3. Render the widget
w <- deckgl(spec)
htmlwidgets::saveWidget(w, "index.html", selfcontained = FALSE)
print("Saved to index.html")
w
library(rDeckgl)
library(duckdb)
library(DBI)
# 1. Setup DuckDB with some polygon data
con <- dbConnect(duckdb())
dbExecute(con, "INSTALL spatial; LOAD spatial;")
dbExecute(con, "CREATE TABLE polygons (id INTEGER, geom GEOMETRY, color VARCHAR)")
# Insert two squares
# Square 1: Red
dbExecute(con, "INSERT INTO polygons VALUES (1, ST_GeomFromText('POLYGON((-122.4 37.76, -122.4 37.77, -122.39 37.77, -122.39 37.76, -122.4 37.76))'), '#FF0000')")
# Square 2: Green
dbExecute(con, "INSERT INTO polygons VALUES (2, ST_GeomFromText('POLYGON((-122.41 37.75, -122.41 37.76, -122.40 37.76, -122.40 37.75, -122.41 37.75))'), '#00FF00')")
# 2. Define the Deck.gl spec
spec <- list(
initialViewState = list(
longitude = -122.4,
latitude = 37.76,
zoom = 12,
pitch = 0,
bearing = 0
),
layers = list(
list(
"@@type" = "GeoArrowSolidPolygonLayer",
id = "polygon-layer",
data = list(
type = "duckdb",
# IMPORTANT: Select as 'geometry' for the JS hack to detect it
query = "SELECT ST_AsWKB(geom) as geometry, color FROM polygons"
),
getFillColor = htmlwidgets::JS("d => {
// Parse hex color to RGB
const hex = d.color;
const r = parseInt(hex.slice(1, 3), 16);
const g = parseInt(hex.slice(3, 5), 16);
const b = parseInt(hex.slice(5, 7), 16);
return [r, g, b];
}"),
pickable = TRUE
)
)
)
# 3. Render
# We pass the connection implicitly? No, deckgl() creates its own connection.
# Wait, deckgl() creates a NEW connection and allows passing dataframes.
# It does NOT allow passing an existing connection or querying tables created outside.
# This is a limitation of the current deckgl() implementation in R/deckgl.R.
# It creates a fresh connection: `con <- DBI::dbConnect(duckdb::duckdb())`
# I need to modify R/deckgl.R to allow passing an existing connection OR
# I need to pass the data as a dataframe to deckgl() so it writes it to the new connection.
# Let's extract the data to a dataframe first, then pass it to deckgl().
# But wait, if I extract it to a dataframe in R, I might lose the WKB nature if not careful.
# R's DBI::dbGetQuery will return blob columns as lists of raw vectors.
# deckgl() will then write this dataframe to the new DuckDB connection.
# DBI::dbWriteTable supports writing blobs.
# Let's try the dataframe approach first.
df_polygons <- dbGetQuery(con, "SELECT ST_AsWKB(geom) as geometry, color FROM polygons")
dbDisconnect(con)
# Now pass this dataframe to deckgl
# The spec query will then query this table.
# We'll name the table 'my_polygons' in the `data` argument.
spec$layers[[1]]$data$query <- "SELECT geometry, color FROM my_polygons"
w <- deckgl(spec, data = list(my_polygons = df_polygons))
htmlwidgets::saveWidget(w, "index_poly.html", selfcontained = FALSE)
print("Saved to index_poly.html")
w
